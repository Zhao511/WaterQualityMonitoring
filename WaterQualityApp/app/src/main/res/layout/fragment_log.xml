<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#f0f2f5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="工作日志"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#2c3e50" />
        <TextView
            android:id="@+id/txt_log_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#95a5a6"
            android:layout_marginEnd="8dp" />
    </LinearLayout>

    <!-- 类型筛选 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp">

        <Button android:id="@+id/btn_log_all" android:layout_width="0dp" android:layout_height="32dp"
            android:layout_weight="1" android:text="全部" android:textSize="11sp" android:layout_marginEnd="3dp" />
        <Button android:id="@+id/btn_log_info" android:layout_width="0dp" android:layout_height="32dp"
            android:layout_weight="1" android:text="信息" android:textSize="11sp" android:layout_marginEnd="3dp" />
        <Button android:id="@+id/btn_log_success" android:layout_width="0dp" android:layout_height="32dp"
            android:layout_weight="1" android:text="成功" android:textSize="11sp" android:layout_marginEnd="3dp" />
        <Button android:id="@+id/btn_log_warning" android:layout_width="0dp" android:layout_height="32dp"
            android:layout_weight="1" android:text="警告" android:textSize="11sp" android:layout_marginEnd="3dp" />
        <Button android:id="@+id/btn_log_error" android:layout_width="0dp" android:layout_height="32dp"
            android:layout_weight="1" android:text="错误" android:textSize="11sp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_logs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">
        <Button
            android:id="@+id/btn_export_log"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="导出 CSV"
            android:layout_marginEnd="8dp" />
        <Button
            android:id="@+id/btn_clear_log"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="清空日志"
            android:backgroundTint="#e74c3c" />
    </LinearLayout>

    <TextView
        android:id="@+id/txt_log_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="暂无日志记录"
        android:textSize="14sp"
        android:textColor="#999"
        android:gravity="center"
        android:visibility="gone" />
</LinearLayout>
