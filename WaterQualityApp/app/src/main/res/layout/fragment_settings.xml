<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ===== 连接状态卡片 ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="2dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="连接状态" android:textSize="16sp" android:textStyle="bold" android:textColor="#333" />
                    <TextView android:id="@+id/label_conn_status"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="未连接" android:textSize="13sp" android:textColor="#E74C3C"
                        android:background="#FDEDEC" android:paddingHorizontal="10dp" android:paddingVertical="4dp" />
                </LinearLayout>

                <EditText android:id="@+id/input_ak"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:hint="Access Key (AK)" android:inputType="text"
                    android:background="@drawable/edit_bg" android:paddingHorizontal="12dp" />

                <EditText android:id="@+id/input_sk"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:hint="Secret Key (SK)" android:inputType="textPassword"
                    android:background="@drawable/edit_bg" android:paddingHorizontal="12dp" />

                <EditText android:id="@+id/input_project_id"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:hint="Project ID" android:inputType="text"
                    android:background="@drawable/edit_bg" android:paddingHorizontal="12dp" />

                <EditText android:id="@+id/input_product_id"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:hint="Product ID (产品ID)" android:inputType="text"
                    android:background="@drawable/edit_bg" android:paddingHorizontal="12dp" />

                <EditText android:id="@+id/input_endpoint"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:hint="Endpoint (接入点)" android:inputType="textUri"
                    android:background="@drawable/edit_bg" android:paddingHorizontal="12dp" />

                <Button android:id="@+id/btn_connect"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:layout_marginTop="12dp"
                    android:text="保存并连接" android:textColor="#FFF" android:textSize="15sp"
                    android:backgroundTint="#2196F3" />

                <Button android:id="@+id/btn_disconnect"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:layout_marginTop="8dp"
                    android:text="断开连接" android:textColor="#FFF" android:textSize="15sp"
                    android:backgroundTint="#E74C3C"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== 运行模式卡片 ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="2dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="运行模式" android:textSize="16sp" android:textStyle="bold" android:textColor="#333" />

                <LinearLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="12dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:id="@+id/label_mode"
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                        android:text="手动模式" android:textSize="15sp" android:textColor="#666" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_auto_mode"
                        android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="自动模式: 数据超阈值自动触发告警    手动模式: 人工控制告警开关"
                    android:textSize="12sp" android:textColor="#AAA" android:layout_marginTop="6dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== 阈值设置卡片 ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="2dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="阈值设置" android:textSize="16sp" android:textStyle="bold" android:textColor="#333" />

                <!-- 水温 -->
                <TextView android:id="@+id/label_temp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="水温阈值: 50℃" android:textSize="14sp" android:textColor="#555" />
                <LinearLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0℃" android:textSize="11sp" android:textColor="#AAA" />
                    <SeekBar android:id="@+id/seek_temp"
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                        android:max="100" android:progress="50" android:layout_marginHorizontal="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="100℃" android:textSize="11sp" android:textColor="#AAA" />
                </LinearLayout>

                <!-- pH 范围 -->
                <TextView android:id="@+id/label_ph"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="pH范围: 6.0 - 9.0" android:textSize="14sp" android:textColor="#555" />
                <com.google.android.material.slider.RangeSlider
                    android:id="@+id/slider_ph"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:valueFrom="0.0" android:valueTo="14.0" android:stepSize="0.1"
                    app:values="@array/ph_default_range" />

                <!-- TDS -->
                <TextView android:id="@+id/label_tds"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="TDS阈值: 1000 mg/L" android:textSize="14sp" android:textColor="#555" />
                <LinearLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="11sp" android:textColor="#AAA" />
                    <SeekBar android:id="@+id/seek_tds"
                        android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                        android:max="2000" android:progress="1000" android:layout_marginHorizontal="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="2000" android:textSize="11sp" android:textColor="#AAA" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== 关于 / 版本信息卡片 ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="2dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="版本信息" android:textSize="16sp" android:textStyle="bold" android:textColor="#333" />

                <TextView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="智慧水质监测系统 v1.0.0" android:textSize="14sp" android:textColor="#555" />

                <TextView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="物模型：DeviceStatus / Water_status / gps / Alarm&#10;连接方式：华为云 IoTDA SDK + Web 后端 REST API"
                    android:textSize="12sp" android:textColor="#95a5a6" />

                <Button android:id="@+id/btn_clear_cache"
                    android:layout_width="match_parent" android:layout_height="40dp"
                    android:layout_marginTop="12dp"
                    android:text="清除本地缓存" android:textSize="13sp"
                    android:backgroundTint="#95A5A6" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== 连接指南卡片 ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="2dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="连接指南" android:textSize="16sp" android:textStyle="bold" android:textColor="#333" />

                <TextView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="1. 登录华为云控制台 → IoTDA&#10;2. 创建产品并获取 Product ID&#10;3. 在 我的凭证 中获取 AK/SK&#10;4. 在 IoTDA 实例概览页获取接入点 Endpoint&#10;5. 确保 Web 后端 server.js 已启动"
                    android:textSize="12sp" android:textColor="#7f8c8d"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
